# Configurações do Banco de Dados (Prisma)
DATABASE_URL="file:./dev.db"

# Configurações de Autenticação
JWT_SECRET="coloque_aqui_uma_string_aleatoria_para_o_jwt"

# Configurações do Servidor
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# CORS — origens permitidas separadas por vírgula
ALLOWED_ORIGINS="http://localhost:3000"

# Swagger — habilitar apenas em desenvolvimento
# ENABLE_SWAGGER=true

# Seed — credenciais do administrador inicial (OBRIGATÓRIO para rodar prisma db seed)
SEED_ADMIN_EMAIL="admin@exemplo.com"
SEED_ADMIN_USERNAME="admin"
SEED_ADMIN_PASSWORD="troque_esta_senha_antes_de_rodar"

# Mercado Pago — usado para gerar o link de pagamento (Pix/débito/crédito) dos pedidos.
# Use uma credencial de TESTE (TEST-...) para não movimentar dinheiro real.
MERCADO_PAGO_ACCESS_TOKEN=""
