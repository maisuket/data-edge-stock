generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
  SUPER_ADMIN
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PAID
  CANCELLED
  COMPLETED
}

enum DeliveryType {
  PICKUP
  DELIVERY
}

enum PaymentMethod {
  PIX
  CREDIT_CARD
  DEBIT_CARD
  CASH
}

model User {
  id             String          @id @default(uuid())
  email          String          @unique
  username       String          @unique
  name           String
  cargo          String?         @default("EMPLOYEE")
  role           Role            @default(USER)
  password       String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  productions    Production[]
  stockMovements StockMovement[]
  priceHistories ProductPriceHistory[]
  sales          Sale[]
  purchases      Purchase[]

  @@map("users")
}

model Supplier {
  id             String          @id @default(uuid())
  name           String
  cnpj           String?         @unique
  email          String?
  phone          String?
  address        String?
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt
  ingredientLots IngredientLot[]
  stockMovements StockMovement[]
  purchases      Purchase[]

  @@map("suppliers")
}

model Product {
  id             String          @id @default(uuid())
  name           String
  category       String
  internalCode   String          @unique @map("internal_code")
  barcode        String?         @unique
  unit           String
  costPrice      Decimal         @map("cost_price")
  salePrice      Decimal?        @map("sale_price")
  currentStock   Decimal         @map("current_stock")
  minStock       Decimal         @map("min_stock")
  location       String?
  imageUrl       String?         @map("image_url")
  isManufactured Boolean         @default(false) @map("is_manufactured")
  /// Quantas unidades do produto uma execução da receita produz
  yieldQuantity  Decimal         @default(1) @map("yield_quantity")
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  attachments    Attachment[]
  productions    Production[]
  recipeItems    RecipeItem[]
  specifications Specification[]
  stockMovements StockMovement[]
  priceHistories ProductPriceHistory[]
  saleItems      SaleItem[]
  orderItems     OrderItem[]

  @@map("products")
}

model StockMovement {
  id          String    @id @default(uuid())
  productId   String?   @map("product_id")
  ingredientId String?  @map("ingredient_id")
  type        String
  batch       String?
  quantity    Decimal
  expiryDate  DateTime? @map("expiry_date")
  unitValue   Decimal?  @map("unit_value")
  stockBefore Decimal   @map("stock_before")
  stockAfter  Decimal   @map("stock_after")
  description String?
  userId      String    @map("user_id")
  supplierId  String?   @map("supplier_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  product     Product?  @relation(fields: [productId], references: [id])
  ingredient  Ingredient? @relation(fields: [ingredientId], references: [id])
  supplier    Supplier? @relation(fields: [supplierId], references: [id])
  user        User      @relation(fields: [userId], references: [id])

  @@index([productId, createdAt])
  @@index([ingredientId, createdAt])
  @@map("stock_movements")
}

model ProductPriceHistory {
  id           String   @id @default(uuid())
  productId    String   @map("product_id")
  oldCostPrice Decimal  @map("old_cost_price")
  newCostPrice Decimal  @map("new_cost_price")
  oldSalePrice Decimal? @map("old_sale_price")
  newSalePrice Decimal? @map("new_sale_price")
  userId       String   @map("user_id")
  createdAt    DateTime @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@map("product_price_history")
}

model Specification {
  id        String  @id @default(uuid())
  name      String
  value     String
  productId String  @map("product_id")
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("specifications")
}

model Attachment {
  id        String   @id @default(uuid())
  fileName  String
  filePath  String
  fileType  String
  productId String   @map("product_id")
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("attachments")
}

/// Insumo: matéria-prima usada na produção (leite, açúcar, etc.)
model Ingredient {
  id                     String                  @id @default(uuid())
  name                   String
  /// Unidade de medida: LITER | ML | KG | G | UNIT
  unit                   String
  currentStock           Decimal                 @default(0) @map("current_stock")
  /// Custo médio ponderado calculado automaticamente a cada compra
  averageCost            Decimal                 @default(0) @map("average_cost")
  minStock               Decimal                 @default(0) @map("min_stock")
  createdAt              DateTime                @default(now()) @map("created_at")
  updatedAt              DateTime                @updatedAt @map("updated_at")
  lots                   IngredientLot[]
  productionConsumptions ProductionConsumption[]
  recipeItems            RecipeItem[]
  stockMovements         StockMovement[]

  @@map("ingredients")
}

/// Lote de compra de insumo — base para FIFO e rastreabilidade
model IngredientLot {
  id           String     @id @default(uuid())
  brand        String?
  lotNumber    String     @map("lot_number")
  ingredientId String     @map("ingredient_id")
  /// Quantidade comprada (em unidade do insumo)
  quantity     Decimal
  /// Custo total da nota/compra
  totalCost    Decimal    @map("total_cost")
  /// Custo por unidade = totalCost / quantity (calculado na service)
  unitCost     Decimal    @map("unit_cost")
  /// Quantidade ainda disponível neste lote (para FIFO)
  remainingQty Decimal    @map("remaining_qty")
  purchasedAt  DateTime   @default(now()) @map("purchased_at")
  expiresAt    DateTime?  @map("expires_at")
  supplierId   String?    @map("supplier_id")
  /// Compra (nota) que originou este lote — nulo em lotes anteriores a essa funcionalidade
  purchaseId   String?    @map("purchase_id")
  createdAt    DateTime   @default(now()) @map("created_at")
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
  supplier     Supplier?  @relation(fields: [supplierId], references: [id])
  purchase     Purchase?  @relation(fields: [purchaseId], references: [id])

  @@index([expiresAt])
  @@map("ingredient_lots")
}

/// Cabeçalho de uma compra/nota — agrupa os lotes (IngredientLot) comprados juntos
model Purchase {
  id         String   @id @default(uuid())
  /// Soma do totalCost de todos os itens/lotes desta compra
  totalCost  Decimal  @map("total_cost")
  notes      String?
  supplierId String?  @map("supplier_id")
  userId     String   @map("user_id")
  createdAt  DateTime @default(now()) @map("created_at")

  supplier Supplier?       @relation(fields: [supplierId], references: [id])
  user     User            @relation(fields: [userId], references: [id])
  lots     IngredientLot[]

  @@index([createdAt])
  @@map("purchases")
}

/// Item da receita: qual insumo e quanto é usado por lote (rendimento) da receita
model RecipeItem {
  id           String     @id @default(uuid())
  productId    String     @map("product_id")
  ingredientId String     @map("ingredient_id")
  /// Quantidade do insumo para produzir 1 lote (Product.yieldQuantity unidades) do produto
  quantity     Decimal
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, ingredientId])
  @@map("recipe_items")
}

/// Registro de um lote de produção
model Production {
  id           String                  @id @default(uuid())
  productId    String                  @map("product_id")
  /// Quantas vezes a receita foi executada nesse registro
  batches      Decimal                 @default(1)
  /// Quantidade de unidades produzidas = batches * yieldQuantity (no momento da produção)
  quantity     Decimal
  /// Custo por unidade produzida (calculado)
  unitCost     Decimal                 @map("unit_cost")
  /// Custo total do lote = quantity * unitCost (calculado)
  totalCost    Decimal                 @map("total_cost")
  notes        String?
  userId       String                  @map("user_id")
  producedAt   DateTime                @default(now()) @map("produced_at")
  createdAt    DateTime                @default(now()) @map("created_at")
  consumptions ProductionConsumption[]
  product      Product                 @relation(fields: [productId], references: [id])
  user         User                    @relation(fields: [userId], references: [id])

  @@index([producedAt])
  @@map("productions")
}

/// Consumo de insumo em um lote de produção (snapshot de custo)
model ProductionConsumption {
  id           String     @id @default(uuid())
  productionId String     @map("production_id")
  ingredientId String     @map("ingredient_id")
  /// Quantidade total consumida neste lote de produção
  quantityUsed Decimal    @map("quantity_used")
  /// Custo médio do insumo no momento da produção (snapshot)
  unitCost     Decimal    @map("unit_cost")
  /// quantityUsed * unitCost
  totalCost    Decimal    @map("total_cost")
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
  production   Production @relation(fields: [productionId], references: [id], onDelete: Cascade)

  @@map("production_consumptions")
}

/// Tabela genérica de chave-valor para armazenar configurações do sistema (ex: imagem do login)
model Setting {
  key       String   @id
  value     String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("settings")
}

/// Registro de uma Venda (Frente de Caixa / Pedido)
model Sale {
  id          String     @id @default(uuid())
  /// Valor total final da venda (após descontos)
  totalAmount Decimal    @map("total_amount")
  discount    Decimal?   @default(0)
  notes       String?
  userId      String     @map("user_id")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  user        User       @relation(fields: [userId], references: [id])
  items       SaleItem[]

  @@index([createdAt])
  @@map("sales")
}

/// Itens individuais de uma Venda
model SaleItem {
  id          String   @id @default(uuid())
  saleId      String   @map("sale_id")
  productId   String   @map("product_id")
  quantity    Decimal
  unitPrice   Decimal  @map("unit_price") // Snapshot do preço de venda na hora da compra
  unitCost    Decimal  @map("unit_cost")  // Snapshot do custo na hora da compra (crucial para o lucro real)
  totalPrice  Decimal  @map("total_price") // quantity * unitPrice

  sale        Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product     Product  @relation(fields: [productId], references: [id])

  @@map("sale_items")
}

/// Pedido feito pelo cardápio público, antes de virar uma Sale/venda de fato
model Order {
  id           String      @id @default(uuid())
  /// Código legível do pedido, ex: "PED-0001"
  orderNumber  String      @unique @map("order_number")
  customerName String?     @map("customer_name")
  /// Telefone/WhatsApp do cliente, normalizado com DDI (ex: "5592991433005")
  customerPhone String?    @map("customer_phone")
  notes        String?
  status       OrderStatus @default(PENDING)
  totalAmount  Decimal     @map("total_amount")
  /// URL de pagamento gerada sob demanda (Mercado Pago Checkout Pro)
  paymentLinkUrl      String? @map("payment_link_url")
  /// ID da preferência de pagamento no Mercado Pago
  paymentPreferenceId String? @map("payment_preference_id")
  deliveryType         DeliveryType @default(PICKUP) @map("delivery_type")
  /// Nome do bairro no momento do pedido (snapshot — não referencia DeliveryZone)
  deliveryNeighborhood String?      @map("delivery_neighborhood")
  /// Taxa de entrega no momento do pedido (snapshot — não referencia DeliveryZone)
  deliveryFee          Decimal      @default(0) @map("delivery_fee")
  /// Forma de pagamento escolhida pelo cliente no checkout — nulo em pedidos
  /// anteriores a essa funcionalidade
  paymentMethod        PaymentMethod? @map("payment_method")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  items OrderItem[]

  @@index([createdAt])
  @@index([status])
  @@map("orders")
}

/// Itens individuais de um Pedido do cardápio
model OrderItem {
  id         String  @id @default(uuid())
  orderId    String  @map("order_id")
  productId  String  @map("product_id")
  quantity   Decimal
  unitPrice  Decimal @map("unit_price")
  totalPrice Decimal @map("total_price")

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

/// Bairro com taxa de entrega para o cardápio público
model DeliveryZone {
  id           String   @id @default(uuid())
  neighborhood String   @unique
  fee          Decimal
  active       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("delivery_zones")
}

/// Cadastro agregado de clientes do cardápio (por telefone), atualizado a
/// cada pedido — base para segmentação/promoções futuras. Sem relação com
/// Order (cada Order já guarda seu próprio snapshot de nome/telefone).
model Customer {
  id         String   @id @default(uuid())
  name       String?
  phone      String   @unique
  orderCount Int      @default(0) @map("order_count")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("customers")
}
