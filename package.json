{
  "name": "data-edge-stock",
  "version": "1.0.0",
  "description": "Sistema de controle de estoque desenvolvido pela Data Edge Tecnologia e Consultoria Ltda",
  "author": "Mauro Daisuke",
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "start": "concurrently -k \"npm run start:backend\" \"npm run start:frontend\" \"npm run start:electron\"",
    "start:backend": "cd backend && npm run start:dev",
    "start:frontend": "cd frontend && npm run dev",
    "build:electron": "tsc",
    "start:electron": "wait-on http://localhost:3000 http://localhost:5173 && npm run build:electron && electron .",
    "build": "npm run build:frontend && npm run build:backend && npm run build:electron && electron-builder",
    "build:backend": "cd backend && npm run build && npm prune --production",
    "build:frontend": "cd frontend && npm run build",
    "dist": "npm run build"
  },
  "build": {
    "appId": "com.estoquetcl.estoque",
    "productName": "Stock TCL",
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "directories": {
      "output": "dist-out"
    },
    "asar": true,
    "asarUnpack": [
      "**/node_modules/@prisma/**/*",
      "**/node_modules/.prisma/**/*",
      "**/node_modules/better-sqlite3/**/*",
      "backend/**/*"
    ],
    "files": [
      "dist-electron/**/*",
      "frontend/dist/**/*",
      "backend/dist/**/*",
      "backend/package.json",
      "backend/prisma/**/*",
      "backend/node_modules/**/*"
    ]
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2",
    "wait-on": "^8.0.1",
    "cross-env": "^7.0.3"
  },
  "dependencies": {
    "axios": "^1.7.7"
  }
}
